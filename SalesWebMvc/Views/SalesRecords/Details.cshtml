@model SalesWebMvc.Models.SalesRecord

@{
    ViewData["Title"] = "Details";
}

<h2>@ViewData["Title"]</h2>

<div>
    <h4>Seller: @Model.Seller.Name</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.Date)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.Date)
        </dd>
        <dt>
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.Status)
        </dd>

        @foreach (var item in Model.Items)
        {
            <dt>
                Item
            </dt>
            <dd>
                @item.Item.Name
            </dd>
            <dt>
                Price and Quantity
            </dt>
            <dd>
                @item.Item.Price | @item.Quantity x
            </dd>
            <dt>
                @Html.DisplayFor(modelItem => modelItem.Amount)
            </dt>
            <dd>
                @Html.DisplayFor(modelItem => modelItem.Amount)
            </dd>
        }
        
    </dl>
</div>
<div>
    <a asp-action="SellerSales" asp-route-sellerId="@Model.Seller.Id">Back to List</a>
</div>