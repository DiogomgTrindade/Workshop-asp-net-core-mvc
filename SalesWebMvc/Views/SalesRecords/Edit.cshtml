@using SalesWebMvc.Models.Enums
@model SalesWebMvc.Models.ViewModels.SellerSalesFormViewModel

@{
    ViewData["Title"] = "Edit";
}

<h2>@ViewData["Title"]</h2>

<h4>Seller @Model.Seller?.Name</h4>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <input type="hidden" asp-for="SalesRecord.Id" />
            <input type="hidden" asp-for="SellerId" />

            <div class="form-group">
                <label asp-for="SalesRecord.Date" class="control-label"></label>
                <input asp-for="SalesRecord.Date" class="form-control" />
                <span asp-validation-for="SalesRecord.Date" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="SalesRecord.Status" class="control-label"></label>
                <select asp-for="SalesRecord.Status"
                        asp-items="Html.GetEnumSelectList<SaleStatus>()"
                        class="form-control">
                </select>
            </div>

            <div class="form-group">
                <label asp-for="SalesRecord.Seller" class="control-label"></label>
                <select asp-for="SellerId" asp-items="@(new SelectList(Model.Sellers, "Id", "Name"))" class="form-control"></select>
            </div>

            <div class="form-group">
                <label class="control-label">Items</label>

                <div id="cart-items">

                    @if (Model.SalesRecord.Items != null && Model.SalesRecord.Items.Any())
                    {
                        foreach (var saleItem in Model.SalesRecord.Items)
                        {
                            <div class="cart-item-row" style="display: flex; gap: 10px; margin-bottom: 10px;">
                                <select name="ItemIds[]" class="form-control item-select">
                                    <option value="">-- Select item --</option>

                                    @foreach (var item in Model.Items)
                                    {
                                        <option value="@item.Id" selected="@(item.Id == saleItem.ItemId)">
                                            @item.Name
                                        </option>
                                    }
                                </select>

                                <input type="number"
                                       name="Quantity[]"
                                       class="form-control item-quantity"
                                       min="1"
                                       value="@saleItem.Quantity"
                                       style="max-width: 100px;" />

                                <button type="button" class="btn btn-danger remove-item">
                                    Remove
                                </button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="cart-item-row" style="display: flex; gap: 10px; margin-bottom: 10px;">
                            <select name="ItemIds[]" class="form-control item-select">
                                <option value="">-- Select item --</option>

                                @foreach (var item in Model.Items)
                                {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            </select>

                            <input type="number"
                                   name="Quantity[]"
                                   class="form-control item-quantity"
                                   min="1"
                                   value="1"
                                   style="max-width: 100px;" />
                        </div>
                    }

                </div>

                <button type="button" id="add-item" class="btn btn-default">
                    Add more to cart
                </button>
            </div>

            <div class="form-group">
                <input type="submit" value="Edit" class="btn btn-default" />

                <a asp-controller="SalesRecords"
                   asp-action="SellerSales"
                   asp-route-sellerId="@Model.SellerId">
                    Back to List
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const cartItemsContainer = document.getElementById('cart-items');
        const addItemButton = document.getElementById('add-item');

        addItemButton.addEventListener('click', function () {
            const firstRow = document.querySelector('.cart-item-row');
            const newRow = firstRow.cloneNode(true);

            const select = newRow.querySelector('.item-select');
            const quantity = newRow.querySelector('.item-quantity');
            const existingRemoveButton = newRow.querySelector('.remove-item');

            select.value = '';
            quantity.value = 1;

            if (existingRemoveButton) {
                existingRemoveButton.remove();
            }

            const removeButton = document.createElement('button');
            removeButton.type = 'button';
            removeButton.textContent = 'Remove';
            removeButton.className = 'btn btn-danger remove-item';

            removeButton.addEventListener('click', function () {
                newRow.remove();
                updateDisabledOptions();
            });

            newRow.appendChild(removeButton);
            cartItemsContainer.appendChild(newRow);

            updateDisabledOptions();
        });

        cartItemsContainer.addEventListener('change', function (e) {
            if (e.target.classList.contains('item-select')) {
                updateDisabledOptions();
            }
        });

        cartItemsContainer.addEventListener('click', function (e) {
            if (e.target.classList.contains('remove-item')) {
                e.target.closest('.cart-item-row').remove();
                updateDisabledOptions();
            }
        });

        function updateDisabledOptions() {
            const selects = document.querySelectorAll('.item-select');

            const selectedValues = Array.from(selects)
                .map(select => select.value)
                .filter(value => value !== '');

            selects.forEach(select => {
                const currentValue = select.value;

                Array.from(select.options).forEach(option => {
                    if (option.value === '') {
                        option.disabled = false;
                        return;
                    }

                    option.disabled =
                        selectedValues.includes(option.value) &&
                        option.value !== currentValue;
                });
            });
        }

        updateDisabledOptions();
    </script>
}